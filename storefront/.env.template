# Get it from the admin dashboard (Settings → Publishable API keys) or:
#   docker exec mercur-postgres psql -U postgres -d mercurjs -t -A \
#     -c "SELECT token FROM api_key WHERE type='publishable' AND revoked_at IS NULL LIMIT 1;"
# Without it, every /store request returns HTTP 400 and the storefront crashes.
